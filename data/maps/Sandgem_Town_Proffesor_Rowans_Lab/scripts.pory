script Sandgem_Town_Proffesor_Rowans_Lab_EventScript_TalK_With_Rival
{
    applymovement(LOCALID_RIVAL_ROWAN_LAB, moves(walk_in_place_left))
    waitmovement(0)
    applymovement(OBJ_EVENT_ID_PLAYER, moves(face_right))
    waitmovement(0)
    if (var(VAR_RESULT) == MALE)
    {
        msgbox("Dawn: I'm so glad that you're kind\n"
                "toward Pokémon!\p"
                "If you weren't, I'd have to...\n"
                "Oh, I just can't say it...", MSGBOX_SIGN)
    }
    elif (var(VAR_RESULT) == FEMALE)
    {
        msgbox("Lucas: Boy, am I glad you're kind\n"
                "toward Pokémon.\p"
                "If you weren't, well...\n"
                "I don't even want to think about it.", MSGBOX_SIGN)
    }
    applymovement(LOCALID_RIVAL_ROWAN_LAB, moves(walk_in_place_left))
    waitmovement(0)
    applymovement(OBJ_EVENT_ID_PLAYER, moves(face_up))
    waitmovement(0)
    goto(Sandgem_Town_Proffesor_Rowans_Lab_EventScript_Rowans_Main_Topic)
}

script Sandgem_Town_Proffesor_Rowans_Lab_EventScript_Rowans_Main_Topic
{
    fadenewbgm(MUS_DP_ROWAN)
    msgbox("Professor: Er-hem!\n"
            "Let's move on to the main topic.\p"
            "There is something I want you to do\n"
            "for me.\p"
            "Allow me to properly introduce myself\n"
            "first.\p"
            "My name, as you know, is Rowan.\n"
            "I study Pokémon.\p"
            "First of all, I want to know exactly\n"
            "what kinds of Pokémon live in the\l"
            "Sinnoh region.\p"
            "To do so, it is necessary to collect\n"
            "data using Pokedex.\p"
            "That is what I wish to ask you.\p"
            "I want to entrust you with this\n"
            "Pokedex.\p"
            "Will you use it to record data on all\n"
            "the Pokémon in Sinnoh for me?", MSGBOX_YESNO)
    goto_if_eq(VAR_RESULT, YES, Sandgem_Town_Proffesor_Rowans_Lab_EventScript_Rowans_Continues_On)
    goto_if_eq(VAR_RESULT, NO, Sandgem_Town_Proffesor_Rowans_Lab_EventScript_Rowans_Forces_Yes)
}

script Sandgem_Town_Proffesor_Rowans_Lab_EventScript_Rowans_Forces_Yes
{
    msgbox("Rowan:...\p"
            "...\p"
            "...\p"
            "I can stand here without speaking for\n"
            "hours. I'm a very patient man.\p"
            "I want to entrust you with this\n"
            "Pokedex.\p"
            "Will you use it to record data on all\n"
            "the Pokémon in Sinnoh for me?", MSGBOX_YESNO)
    goto_if_eq(VAR_RESULT, YES, Sandgem_Town_Proffesor_Rowans_Lab_EventScript_Rowans_Continues_On)
    goto_if_eq(VAR_RESULT, NO, Sandgem_Town_Proffesor_Rowans_Lab_EventScript_Rowans_Forces_Yes)
}

script Sandgem_Town_Proffesor_Rowans_Lab_EventScript_Rowans_Continues_On
{
    msgbox("Rowan: Hm!\p"
            "Good Answer!", MSGBOX_SIGN)
    playfanfare(MUS_DP_OBTAIN_KEY_ITEM)
    setflag(FLAG_SYS_POKEDEX_GET)
    msgbox("{PLAYER} obtained\n"
            "the Pokedex!", MSGBOX_SIGN)
    msgbox("Rowan: That Pokedex is a very\n"
            "high-tech device.\p"
            "It will automatically record data on\n"
            "every kind of Pokémon you encounter.\p"
            "{PLAYER}, I ask that you go\n"
            "everywhere and meet every kind of\l"
            "Pokémon in this region!", MSGBOX_SIGN)
    goto(Sandgem_Town_Proffesor_Rowans_Lab_EventScript_Rival_Talks_About_Pokedex)
}

script Sandgem_Town_Proffesor_Rowans_Lab_EventScript_Rival_Talks_About_Pokedex
{
    applymovement(LOCALID_RIVAL_ROWAN_LAB, moves(walk_in_place_left))
    waitmovement(0)
    checkplayergender()
    if (var(VAR_RESULT) == MALE)
    {
        msgbox("Dawn: I've got one, too!\p"
                "Rowan: When you walked up Route 201\n"
                "with your Pokémon, what did you feel?\p"
                "I've lived for 60 long years.\n"
                "Even now, I get a thrill when\p"
                "I'm with a Pokémon.\p"
                "Now, you should know that there are\n"
                "countless Pokémon in this world.\p"
                "That means there are just as many\n"
                "thrills waiting for you out here!\p"
                "Now go!\p"
                "{PLAYER}, your grand adventure\n"
                "begins right now!", MSGBOX_SIGN)
    }
    elif (var(VAR_RESULT) == FEMALE)
    {
        msgbox("Lucas: I've got the same kind of\n"
                "Pokédex as you.\p"
                "Rowan: When you walked up Route 201\n"
                "with your Pokémon, what did you feel?\p"
                "I've lived for 60 long years.\n"
                "Even now, I get a thrill when\p"
                "I'm with a Pokémon.\p"
                "Now, you should know that there are\n"
                "countless Pokémon in this world.\p"
                "That means there are just as many\n"
                "thrills waiting for you out here!\p"
                "Now go!\p"
                "{PLAYER}, your grand adventure\n"
                "begins right now!", MSGBOX_SIGN)
    }
    applymovement(LOCALID_RIVAL_ROWAN_LAB, moves(walk_in_place_left))
    waitmovement(0)
    applymovement(OBJ_EVENT_ID_PLAYER, moves(face_right))
    waitmovement(0)
    checkplayergender()
    if (var(VAR_RESULT) == MALE)
    {
        switch (var(VAR_STARTER_MON))
        {
            case 0: goto(Sandgem_Town_Proffesor_Rowans_Lab_EventScript_Dawn_Talks_About_First_Mon_Piplup)
            case 1: goto(Sandgem_Town_Proffesor_Rowans_Lab_EventScript_Dawn_Talks_About_First_Mon_Turtwig)
            case 2: goto(Sandgem_Town_Proffesor_Rowans_Lab_EventScript_Dawn_Talks_About_First_Mon_Chimchar)
        }
    }
    elif (var(VAR_RESULT) == FEMALE)
    {
        goto(Sandgem_Town_Proffesor_Rowans_Lab_EventScript_Lucas_Talks_About_First_Mon)
    }
}

script Sandgem_Town_Proffesor_Rowans_Lab_EventScript_Dawn_Talks_About_First_Mon_Piplup
{
    msgbox("Dawn: The Pokémon that I met for\n"
            "the first time was a Piplup!\p"
            "If you would have choosen a Piplup\n"
            "on Route 201, we'd have the same\l"
            "Pokémon now!\l"
            "Not that it matters, but...\l"
            "Anyway, I'm Dawn.\p"
            "I also help the professor add pages\n"
            "to the Pokedex.\l"
            "So, in a sense, I'm just like you.\p"
            "I just got a little head start on you,\n"
            "that's all.\p"
            "I'll be happy to teach you things.\n"
            "Glad to meet you, {PLAYER}", MSGBOX_SIGN)
    goto(Sandgem_Town_Proffesor_Rowans_Lab_EventScript_Rival_Leaves)
}

