script Sandgem_Town_Proffesor_Rowans_Lab_EventScript_NicknameStarter
{
    setvar(VAR_0x8004, 0)
    call(Common_EventScript_NameReceivedPartyMon)
    goto(Sandgem_Town_Proffesor_Rowans_Lab_EventScript_Script_Continues)
}

script Sandgem_Town_Proffesor_Rowans_Lab_EventScript_Script_Continues
{
    switch (var(VAR_STARTER_MON))
    {
        case 0: goto(Sandgem_Town_Proffesor_Rowans_Lab_EventScript_Script_Continues_Turtwig)
        case 1: goto(Sandgem_Town_Proffesor_Rowans_Lab_EventScript_Script_Continues_Chimchar)
        case 2: goto(Sandgem_Town_Proffesor_Rowans_Lab_EventScript_Script_Continues_Piplup)
    }
}

script Sandgem_Town_Proffesor_Rowans_Lab_EventScript_Script_Continues_Turtwig
{
    msgbox("Professor: When I first saw you two\n"
            "about to step into the tall grass\l"
            "without Pokémon, I was shocked.\p"
            "I was astounded by these foolhardy\n"
            "children.\p"
            "But now, you've astounded me in an\n"
            "entirely different way.\p"
            "Already, there is a bond growing\n"
            "between you and that Pokémon.\p"
            "I feel priviliged to have met you.\p"
            "I'm sure Turtwig feels the same\n"
            "way about you.\p"
            "That's why I'll ask you to cherish that\n"
            "Turtwig of yours.", MSGBOX_SIGN)
    checkplayergender
    goto(Sandgem_Town_Proffesor_Rowans_Lab_EventScript_TalK_With_Rival)
}

