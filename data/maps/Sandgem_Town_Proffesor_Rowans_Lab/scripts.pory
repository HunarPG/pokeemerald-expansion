{
    msgbox("The refrigerator is filled with\n"
            "tasty sweets! Mmm...", MSGBOX_SIGN)
}

script Sandgem_Town_Proffesor_Rowans_Lab_Female_Scientist
{
    msgbox("Professor Rowan invented a new\n"
            "Pokedex while working alongside a\l"
            "proffesor from the Kanto region.\p"
            "Oh, my name is Roseanne.\p"
            "It's an honor to be an assistant to\n"
            "our professor!", MSGBOX_NPC)
}
script Sandgem_Town_Proffesor_Rowans_Lab_Male_Scientist
{
    if (var(VAR_RESULT) == MALE)
    {
        msgbox("I'm Dawn's father.\p"
                "I'll be happy to assist you on your\n"
                "quest for the professor\p"
                "Hahaha. Eh...\n"
                "I'm sure we can count on you!", MSGBOX_NPC)
    }
    elif (var(VAR_RESULT) == FEMALE)
    {
        msgbox("I'm Lucas's father.\p"
                "I'll be happy to assist you on your\l"
                "quest for the professor\p"
                "Hahaha. Eh...\n"
                "I'm sure we can count on you!", MSGBOX_NPC)
    }
}
