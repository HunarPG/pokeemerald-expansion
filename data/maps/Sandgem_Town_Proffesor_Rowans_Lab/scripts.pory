script Sandgem_Town_Proffesor_Rowans_Lab_EventScript_Lucas_Talks_About_First_Mon
{
    msgbox("Lucas: The professor asked me to help,\n"
            "so I'm filling the Pokédex pages, too.\p"
            "That makes us comrades working toward\n"
            "the same goal.\p"
            "I'll teach you stuff later, OK?", MSGBOX_SIGN)
    goto(Sandgem_Town_Proffesor_Rowans_Lab_EventScript_Rival_Leaves)
}

script Sandgem_Town_Proffesor_Rowans_Lab_EventScript_Rival_Leaves
{
    applymovement(OBJ_EVENT_ID_PLAYER, moves(face_down))
    applymovement(LOCALID_RIVAL_ROWAN_LAB, moves(walk_down * 7))
    waitmovement(0)
    setvar(VAR_ROWANS_LAB_STATE, 1)
    removeobject(LOCALID_RIVAL_ROWAN_LAB)
    setflag(FLAG_HIDE_RIVAL_IN_SANDGEM_LAB)
    setvar(VAR_SANDGEM_TOWN_STATE, 1)
    end()
}

script Sandgem_Town_Proffesor_Rowans_Lab_Rowan
{
    switch (var(VAR_SANDGEM_TOWN_STATE))
    {
        case 1: goto(Sandgem_Town_Proffesor_Rowans_Lab_Rowan_Grand_Adventure)
        case 2: goto(Sandgem_Town_Proffesor_Rowans_Lab_Rowan_Check_Pokedex_Progress)
    }
}

script Sandgem_Town_Proffesor_Rowans_Lab_Rowan_Grand_Adventure
{
    msgbox("Rowan: Go on!\p"
            "{PLAYER}, your grand adventure\n"
            "awaits you!", MSGBOX_NPC)
    end()
}

script Sandgem_Town_Proffesor_Rowans_Lab_Rowan_Check_Pokedex_Progress
{
    lock()
    faceplayer()
    msgbox("Rowan: Ah, {PLAYER}\p"
            "You've come to show me the progress\n"
            "you've made on your Pokedex", MSGBOX_YESNO)
    goto_if_eq(VAR_RESULT, YES, Sandgem_Town_Proffesor_Rowans_Lab_Rowan_Check_Pokedex_Progress_No)
    goto_if_eq(VAR_RESULT, NO, Sandgem_Town_Proffesor_Rowans_Lab_Rowan_Check_Pokedex_Progress_Yes)
}

script Sandgem_Town_Proffesor_Rowans_Lab_Rowan_Check_Pokedex_Progress_No
{
    msgbox("What's wrong?\p"
            "You're not suggesting you've seen so\n"
            "few that you're afraid to show me?", MSGBOX_SIGN)
    release()
    end()
}

script Sandgem_Town_Proffesor_Rowans_Lab_Rowan_Check_Pokedex_Progress_Yes
{
    # todo = implement pokedex progress check
    release()
    end()
}

