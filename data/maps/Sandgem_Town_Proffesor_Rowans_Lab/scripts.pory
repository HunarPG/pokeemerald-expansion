mapscripts Sandgem_Town_Proffesor_Rowans_Lab_MapScripts
{
    MAP_SCRIPT_ON_FRAME_TABLE
    [
        VAR_ROWANS_LAB_STATE, 0 : Sandgem_Town_Proffesor_Rowans_Lab_EventScript_Reached_First_Time_Event
    ]
}

script Sandgem_Town_Proffesor_Rowans_Lab_EventScript_Reached_First_Time_Event
{
    delay(30)
    applymovement(LOCALID_RIVAL_ROWAN_LAB, moves(walk_up * 8, walk_right, face_left))
    applymovement(OBJ_EVENT_ID_PLAYER, moves(walk_up * 9))
    waitmovement(0)
    switch (var(VAR_STARTER_MON))
    {
        case 0: goto(Sandgem_Town_Proffesor_Rowans_Lab_EventScript_Turtwig)
        case 1: goto(Sandgem_Town_Proffesor_Rowans_Lab_EventScript_Chimchar)
        case 2: goto(Sandgem_Town_Proffesor_Rowans_Lab_EventScript_Piplup)
    }
}

script Sandgem_Town_Proffesor_Rowans_Lab_EventScript_Turtwig
{
    msgbox("Professor: Well, well, look who's here.\p"
            "{PLAYER}, was it?\n"
            "Let's have a look at your Pokémon.\p"
            "...\p"
            "Hm...\n"
            "I see...\p"
            "This Pokémon seems to be rather\n"
            "happy.\p"
            "Hm!\p"
            "Entrusting you with that Turtwig\n"
            "was no mistake it seems!\p"
            "Professor: Well, would you like to give\n"
            "it a nickname?", MSGBOX_YESNO)
    goto_if_eq(VAR_RESULT, YES, Sandgem_Town_Proffesor_Rowans_Lab_EventScript_NicknameStarter)
    goto_if_eq(VAR_RESULT, NO, Sandgem_Town_Proffesor_Rowans_Lab_EventScript_Script_Continues)
}

