    msgbox("Ace Trainer is the kind of Trainer\n"
            "you want to be?", MSGBOX_YESNO)
    goto_if_eq(VAR_RESULT, TRUE, OreburghCityPokemonCenter1F_EventScript_Players_Will_See_You_Ruin_Maniac)
